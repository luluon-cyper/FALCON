import tkinter as tk
from tkinter import filedialog, messagebox, ttk
import os
import shutil

output_files = ["public.key", "private.key"]

def process_files():
    for file in output_files:
        with open(file, "w", encoding="utf-8") as f:
            f.write("demo-key-data-2026")
    
    lbl_status.config(text="✨ Đã tạo Key thành công!", foreground="#27ae60")
    show_outputs()

def download_file(filename):
    if not os.path.exists(filename):
        messagebox.showerror("Lỗi", "File không tồn tại, hãy nhấn 'TẠO KEY' trước!")
        return

    save_path = filedialog.asksaveasfilename(
        initialfile=filename,
        defaultextension=".key",
        filetypes=[("Key files", "*.key")]
    )

    if save_path:
        shutil.copy(filename, save_path)
        messagebox.showinfo("Thành công", f"Đã lưu {filename} thành công!")

def show_outputs():
    for widget in frame_list.winfo_children():
        widget.destroy()

    for file in output_files:
        row = ttk.Frame(frame_list, padding=5)
        row.pack(fill="x", pady=2)
        
        lbl_icon = ttk.Label(row, text="📄", font=("Segoe UI", 12))
        lbl_icon.pack(side="left", padx=(0, 10))
        
        lbl_name = ttk.Label(row, text=file, font=("Segoe UI", 10))
        lbl_name.pack(side="left")
        
        btn_dl = ttk.Button(row, text="Tải về", width=10, 
                            command=lambda f=file: download_file(f))
        btn_dl.pack(side="right")
        
        sep = ttk.Separator(frame_list, orient="horizontal")
        sep.pack(fill="x", padx=5)

root = tk.Tk()
root.title("Key Generation System v2.0")
root.geometry("480x420")
root.configure(bg="#f5f7f9")

style = ttk.Style()
style.configure("Header.TLabel", font=("Segoe UI", 15, "bold"), foreground="#2c3e50")
style.configure("Primary.TButton", font=("Segoe UI", 10, "bold"))

header = ttk.Label(root, text="HỆ THỐNG QUẢN LÝ KHÓA", style="Header.TLabel", background="#f5f7f9")
header.pack(pady=20)

frame_action = ttk.Frame(root, padding=10)
frame_action.pack(fill="x", padx=20)

btn_process = ttk.Button(frame_action, text="⚡ TẠO CẶP KHÓA MỚI", 
                         width=30, style="Primary.TButton", command=process_files)
btn_process.pack(pady=10)

lbl_status = ttk.Label(frame_action, text="Nhấn nút để bắt đầu tạo Key", font=("Segoe UI", 9, "italic"))
lbl_status.pack()

frame_results = ttk.LabelFrame(root, text=" Danh sách file kết quả ", padding=15)
frame_results.pack(padx=20, pady=15, fill="both", expand=True)

frame_list = ttk.Frame(frame_results)
frame_list.pack(fill="both", expand=True)

lbl_empty = ttk.Label(frame_list, text="Chưa có dữ liệu đầu ra...", foreground="#bdc3c7")
lbl_empty.pack(pady=20)

footer = tk.Label(root, text="© 2026 Security Module Interface", font=("Segoe UI", 8), 
                  bg="#f5f7f9", fg="#bdc3c7")
footer.pack(side="bottom", pady=10)

root.mainloop()